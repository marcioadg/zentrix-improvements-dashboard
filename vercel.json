{
  "outputDirectory": ".",
  "buildCommand": "npm ci --prefix admin-app --legacy-peer-deps && npm run build --prefix admin-app && mkdir -p admin company-management && cp admin-bundle/app.html admin/index.html && cp admin-bundle/app.html company-management/index.html && rm -rf admin-app",
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/admin/index.html"
    },
    {
      "source": "/company-management",
      "destination": "/company-management/index.html"
    },
    {
      "source": "/login",
      "destination": "/admin/index.html"
